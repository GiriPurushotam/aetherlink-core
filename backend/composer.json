{
  "name": "aetherlink/core",
  "description": "Hybrid Web2.5 Real-Time Data Indexing and Webhook Orchestration Engine",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "AetherLink\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
